<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="batch_performance_summary" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7b9d24e5-5c93-46f8-a2f8-ead101000001">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="Student Result System MySQL"/>
    <queryString>
        <![CDATA[
SELECT s.student_id,
       s.full_name,
       s.pathway,
       m.module_code,
       m.module_name,
       m.credit_hours,
       r.total_mark,
       r.grade_letter,
       r.grade_point,
       r.status,
       (SELECT AVG(r2.total_mark) FROM results r2) AS class_average,
       (SELECT MAX(r2.total_mark) FROM results r2) AS highest_mark,
       (SELECT MIN(r2.total_mark) FROM results r2) AS lowest_mark,
       (SELECT 100.0 * SUM(r2.status='PASS') / NULLIF(COUNT(*),0) FROM results r2) AS pass_rate,
       (SELECT COUNT(*) FROM results r2 WHERE r2.grade_letter='A') AS grade_a_count,
       (SELECT COUNT(*) FROM results r2 WHERE r2.grade_letter='B') AS grade_b_count,
       (SELECT COUNT(*) FROM results r2 WHERE r2.grade_letter='C') AS grade_c_count,
       (SELECT COUNT(*) FROM results r2 WHERE r2.grade_letter='D') AS grade_d_count,
       (SELECT COUNT(*) FROM results r2 WHERE r2.grade_letter='F') AS grade_f_count
FROM students s
JOIN enrollments e ON e.student_id = s.student_id
JOIN modules m ON m.module_code = e.module_code
LEFT JOIN results r ON r.enrollment_id = e.enrollment_id
ORDER BY s.student_id, m.module_code
        ]]>
    </queryString>
    <field name="student_id" class="java.lang.String"/>
    <field name="full_name" class="java.lang.String"/>
    <field name="pathway" class="java.lang.String"/>
    <field name="module_code" class="java.lang.String"/>
    <field name="module_name" class="java.lang.String"/>
    <field name="credit_hours" class="java.lang.Integer"/>
    <field name="total_mark" class="java.math.BigDecimal"/>
    <field name="grade_letter" class="java.lang.String"/>
    <field name="grade_point" class="java.math.BigDecimal"/>
    <field name="status" class="java.lang.String"/>
    <field name="class_average" class="java.math.BigDecimal"/>
    <field name="highest_mark" class="java.math.BigDecimal"/>
    <field name="lowest_mark" class="java.math.BigDecimal"/>
    <field name="pass_rate" class="java.math.BigDecimal"/>
    <field name="grade_a_count" class="java.lang.Long"/>
    <field name="grade_b_count" class="java.lang.Long"/>
    <field name="grade_c_count" class="java.lang.Long"/>
    <field name="grade_d_count" class="java.lang.Long"/>
    <field name="grade_f_count" class="java.lang.Long"/>
    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="5" width="802" height="28"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Batch Performance Summary Report]]></text>
            </staticText>
        </band>
    </title>
