            <staticText><reportElement x="0" y="55" width="150" height="18"/><textElement><font isBold="true"/></textElement><text><![CDATA[Grade Distribution]]></text></staticText>
            <textField><reportElement x="0" y="75" width="100" height="18"/><textFieldExpression><![CDATA["A: " + $F{grade_a_count}]]></textFieldExpression></textField>
            <textField><reportElement x="100" y="75" width="100" height="18"/><textFieldExpression><![CDATA["B: " + $F{grade_b_count}]]></textFieldExpression></textField>
            <textField><reportElement x="200" y="75" width="100" height="18"/><textFieldExpression><![CDATA["C: " + $F{grade_c_count}]]></textFieldExpression></textField>
