            <textField><reportElement x="200" y="28" width="170" height="18"/><textFieldExpression><![CDATA["Highest Mark: " + $F{highest_mark}]]></textFieldExpression></textField>
            <textField><reportElement x="380" y="28" width="170" height="18"/><textFieldExpression><![CDATA["Lowest Mark: " + $F{lowest_mark}]]></textFieldExpression></textField>
